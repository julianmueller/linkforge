<?xml version="1.0"?>
<robot name="simple_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:arg name="tool_offset" default="0.20"/>
  <xacro:arg name="include_alignment_pin" default="true"/>

  <xacro:property name="base_length" value="0.40"/>
  <xacro:property name="base_width" value="0.20"/>
  <xacro:property name="base_height" value="0.10"/>
  <xacro:property name="tool_size_xy" value="0.08"/>
  <xacro:property name="tool_size_z" value="0.04"/>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
  </link>

  <link name="tool_flange">
    <visual>
      <geometry>
        <box size="${tool_size_xy} ${tool_size_xy} ${tool_size_z}"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <box size="${tool_size_xy} ${tool_size_xy} ${tool_size_z}"/>
      </geometry>
    </collision>
  </link>

  <joint name="tool_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="tool_flange"/>
    <origin xyz="$(arg tool_offset) 0.0 0.0" rpy="0 0 0"/>
  </joint>

  <xacro:if value="$(arg include_alignment_pin)">
    <link name="alignment_pin">
      <visual>
        <geometry>
          <box size="0.02 0.02 0.04"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <box size="0.02 0.02 0.04"/>
        </geometry>
      </collision>
    </link>

    <joint name="alignment_pin_joint" type="fixed">
      <parent link="base_link"/>
      <child link="alignment_pin"/>
      <origin xyz="${base_length / 2} 0.0 ${base_height / 2}" rpy="0 0 0"/>
    </joint>
  </xacro:if>
</robot>
