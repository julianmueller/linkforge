  <!-- Joints -->
  <joint name="front_left_wheel_joint" type="continuous">
    <origin xyz="0.2 0.2 0.05" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="front_left_wheel" />
    <axis xyz="0 1 0" />
    <dynamics damping="0.1" friction="0.05" />
  </joint>
  <joint name="front_right_wheel_joint" type="continuous">
    <origin xyz="0.2 -0.2 0.05" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="front_right_wheel" />
    <axis xyz="0 1 0" />
    <dynamics damping="0.1" friction="0.05" />
  </joint>
  <joint name="caster_joint" type="fixed">
    <origin xyz="-0.25 0 0" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="caster_wheel" />
  </joint>
  <joint name="arm_base_joint" type="revolute">
    <origin xyz="0 0 0.175" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="arm_base" />
    <axis xyz="0 0 1" />
    <limit effort="10" velocity="2" lower="-3.14159" upper="3.14159" />
    <dynamics damping="0.5" friction="0.1" />
  </joint>
  <joint name="shoulder_joint" type="revolute">
    <origin xyz="0 0 0.075" rpy="0 0 0" />
    <parent link="arm_base" />
    <child link="upper_arm" />
    <axis xyz="0 1 0" />
    <limit effort="8" velocity="1.5" lower="-1.57" upper="1.57" />
    <dynamics damping="0.4" friction="0.08" />
  </joint>
  <joint name="elbow_joint" type="revolute">
    <origin xyz="0 0 0.4" rpy="0 0 0" />
    <parent link="upper_arm" />
    <child link="forearm" />
    <axis xyz="0 1 0" />
    <limit effort="5" velocity="1.5" lower="-2" upper="2" />
    <dynamics damping="0.3" friction="0.05" />
  </joint>
  <joint name="wrist_joint" type="revolute">
    <origin xyz="0 0 0.3" rpy="0 0 0" />
    <parent link="forearm" />
    <child link="gripper_base" />
    <axis xyz="0 0 1" />
    <limit effort="2" velocity="2" lower="-3.14159" upper="3.14159" />
    <dynamics damping="0.2" friction="0.02" />
  </joint>
  <joint name="left_finger_joint" type="prismatic">
    <origin xyz="0 0.055 0" rpy="0 0 0" />
    <parent link="gripper_base" />
    <child link="left_finger" />
    <axis xyz="0 1 0" />
    <limit effort="1" velocity="0.5" lower="0" upper="0.04" />
    <dynamics damping="0.1" friction="0.01" />
  </joint>
  <joint name="right_finger_joint" type="prismatic">
    <origin xyz="0 -0.055 0" rpy="0 0 0" />
    <parent link="gripper_base" />
    <child link="right_finger" />
    <axis xyz="0 1 0" />
    <limit effort="1" velocity="0.5" lower="-0.04" upper="0" />
    <dynamics damping="0.1" friction="0.01" />
    <mimic joint="left_finger_joint" multiplier="-1" />
  </joint>
  <joint name="camera_mount_joint" type="fixed">
    <origin xyz="0.3 0 0.1" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="camera_mount" />
  </joint>
  <joint name="lidar_mount_joint" type="fixed">
    <origin xyz="0 0 0.13" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="lidar_mount" />
  </joint>
  <joint name="imu_mount_joint" type="fixed">
    <origin xyz="0 0 0.11" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="imu_mount" />
  </joint>
  <joint name="planar_joint" type="planar">
    <origin xyz="0 0.35 0.05" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="planar_platform" />
    <axis xyz="0 0 1" />
  </joint>
  <joint name="floating_joint" type="floating">
    <origin xyz="0 0 1.2" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="floating_sensor" />
  </joint>
  <!-- Transmissions -->
  <transmission name="diff_drive_transmission">
    <type>transmission_interface/DifferentialTransmission</type>
    <joint name="front_left_wheel_joint">
      <hardwareInterface>velocity</hardwareInterface>
    </joint>
    <joint name="front_right_wheel_joint">
      <hardwareInterface>velocity</hardwareInterface>
    </joint>
    <actuator name="left_motor">
      <hardwareInterface>velocity</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
    <actuator name="right_motor">
      <hardwareInterface>velocity</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <transmission name="arm_base_transmission">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="arm_base_joint">
      <hardwareInterface>effort</hardwareInterface>
    </joint>
    <actuator name="arm_base_motor">
      <hardwareInterface>effort</hardwareInterface>
      <mechanicalReduction>100</mechanicalReduction>
    </actuator>
  </transmission>
  <transmission name="shoulder_transmission">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="shoulder_joint">
      <hardwareInterface>effort</hardwareInterface>
    </joint>
    <actuator name="shoulder_motor">
      <hardwareInterface>effort</hardwareInterface>
      <mechanicalReduction>80</mechanicalReduction>
    </actuator>
  </transmission>
  <transmission name="elbow_transmission">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="elbow_joint">
      <hardwareInterface>effort</hardwareInterface>
    </joint>
    <actuator name="elbow_motor">
      <hardwareInterface>effort</hardwareInterface>
      <mechanicalReduction>60</mechanicalReduction>
    </actuator>
  </transmission>
  <transmission name="wrist_transmission">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="wrist_joint">
      <hardwareInterface>effort</hardwareInterface>
    </joint>
    <actuator name="wrist_motor">
      <hardwareInterface>effort</hardwareInterface>
      <mechanicalReduction>40</mechanicalReduction>
    </actuator>
  </transmission>
  <transmission name="gripper_transmission">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="left_finger_joint">
      <hardwareInterface>effort</hardwareInterface>
    </joint>
    <actuator name="gripper_motor">
      <hardwareInterface>effort</hardwareInterface>
      <mechanicalReduction>20</mechanicalReduction>
    </actuator>
  </transmission>
  <!-- ROS2 Control -->
  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="front_left_wheel_joint">
      <command_interface name="velocity" />
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
    <joint name="front_right_wheel_joint">
      <command_interface name="velocity" />
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
    <joint name="arm_base_joint">
      <command_interface name="effort" />
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <joint name="shoulder_joint">
      <command_interface name="effort" />
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <joint name="elbow_joint">
      <command_interface name="effort" />
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <joint name="wrist_joint">
      <command_interface name="effort" />
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <joint name="left_finger_joint">
      <command_interface name="effort" />
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
  </ros2_control>
  <gazebo>
    <plugin filename="libgz_ros2_control-system.so" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find robot_description)/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>
  <!-- Sensors -->
  <gazebo reference="camera_mount">
    <sensor name="front_camera" type="camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <visualize>false</visualize>
      <topic>camera/image_raw</topic>
      <camera>
        <horizontal_fov>1.0472</horizontal_fov>
        <image>
          <width>1920</width>
          <height>1080</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>100</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>
  <gazebo reference="lidar_mount">
    <sensor name="laser_scanner" type="gpu_lidar">
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <visualize>false</visualize>
      <topic>scan</topic>
      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.1</min>
          <max>30</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <stddev>0.01</stddev>
        </noise>
      </ray>
    </sensor>
  </gazebo>
  <gazebo reference="imu_mount">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>false</visualize>
      <topic>imu/data</topic>
      <imu>
        <angular_velocity>
          <x>
            <noise>
              <type>gaussian</type>
              <stddev>0.0002</stddev>
            </noise>
          </x>
          <y>
            <noise>
              <type>gaussian</type>
              <stddev>0.0002</stddev>
            </noise>
          </y>
          <z>
            <noise>
              <type>gaussian</type>
              <stddev>0.0002</stddev>
            </noise>
          </z>
        </angular_velocity>
        <linear_acceleration>
          <x>
            <noise>
              <type>gaussian</type>
              <stddev>0.0002</stddev>
            </noise>
          </x>
          <y>
            <noise>
              <type>gaussian</type>
              <stddev>0.0002</stddev>
            </noise>
          </y>
          <z>
            <noise>
              <type>gaussian</type>
              <stddev>0.0002</stddev>
            </noise>
          </z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>
</robot>
